AddDefaultCharset UTF-8

<IfModule mod_mime.c>
  AddType text/html;charset=UTF-8 .html .htm
  AddType text/css;charset=UTF-8 .css
  AddType application/javascript;charset=UTF-8 .js .mjs
  AddType application/json;charset=UTF-8 .json
  AddType application/manifest+json;charset=UTF-8 .webmanifest
  AddType image/svg+xml;charset=UTF-8 .svg
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /kuran.emirhangungormez.com.tr/
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . index.html [L]
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(html?|htm)$">
    Header set Content-Type "text/html; charset=UTF-8"
  </FilesMatch>

  <FilesMatch "\.(js|mjs)$">
    Header set Content-Type "application/javascript; charset=UTF-8"
  </FilesMatch>

  <FilesMatch "\.css$">
    Header set Content-Type "text/css; charset=UTF-8"
  </FilesMatch>

  <FilesMatch "\.json$">
    Header set Content-Type "application/json; charset=UTF-8"
  </FilesMatch>

  <FilesMatch "\.webmanifest$">
    Header set Content-Type "application/manifest+json; charset=UTF-8"
  </FilesMatch>

  <FilesMatch "\.svg$">
    Header set Content-Type "image/svg+xml; charset=UTF-8"
  </FilesMatch>

  <FilesMatch "^(index\.html|sw\.js|manifest\.webmanifest)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  <FilesMatch "\.(js|css|png|jpg|jpeg|svg|woff2|ttf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
