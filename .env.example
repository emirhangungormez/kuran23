# Supabase (Vite)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_public_anon_key
VITE_ENABLE_SUPABASE_QURAN=false

# Migration (MySQL -> Supabase)
# Postgres connection string from Supabase: Project Settings -> Database -> Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# Required only if you want the script to create missing auth.users records automatically
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional (defaults below are already used by the script)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=kuran_db
MYSQL_USER=root
MYSQL_PASSWORD=
MIGRATION_BATCH_SIZE=500
MIGRATION_CREATE_MISSING_AUTH=false
MIGRATION_TRUNCATE_FIRST=false

# QUL pilot import (SQLite -> Supabase)
QUL_SQLITE_PATH=C:\\path\\to\\qul-export.sqlite
QUL_SURAH_ID=1
QUL_BATCH_TAG=qul_fatiha_pilot
